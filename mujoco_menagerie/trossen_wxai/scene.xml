<mujoco model="wxai_scene">
  <compiler angle="radian"/>

  <statistic center="0 0 0.1" extent="0.8"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="140" elevation="-30"/>
  </visual>
  <option impratio="10" cone="elliptic"/>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <texture type="2d" file="assets/meshes/table/small_meta_table_diffuse.png"/>

    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="table" texture="small_meta_table_diffuse"/>

    <mesh name="tabletop" file="assets/meshes/table/tabletop.obj"/>
    <mesh name="tablelegs" file="assets/meshes/table/tablelegs.obj"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="2 2 0.05" type="plane" material="groundplane" pos="0 0 -.75"/>

    <!-- Table -->
    <geom mesh="tabletop" material="table" type="mesh" pos="0 0 -0.75" quat="1 0 0 1"/>
    <geom mesh="tablelegs" material="table" type="mesh" pos="0 0 -0.75" quat="1 0 0 1"/>
    <geom name="table_collision" pos="0 0 -0.1009" size="0.61 0.37 0.1" type="box" group="2"/>
  </worldbody>
  <include file="wxai_follower_biarm.xml"/>
</mujoco>
